ASPNETCORE_ENVIRONMENT=Development
LUCY_ENABLE_HTTPS_REDIRECTION=false
POSTGRES_DB=lucy_identity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-identity-db-password
IDENTITY_DB_CONNECTION=Host=localhost;Port=5432;Database=lucy_identity;Username=postgres;Password=replace-with-identity-db-password
ConnectionStrings__IdentityDb=Host=localhost;Port=5432;Database=lucy_identity;Username=postgres;Password=replace-with-identity-db-password
JWT_ISSUER=lucy.identity
JWT_AUDIENCE=lucy.clients
JWT_SIGNING_KEY=replace-with-shared-32-byte-secret
Jwt__Issuer=lucy.identity
Jwt__Audience=lucy.clients
Jwt__SigningKey=replace-with-shared-32-byte-secret
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
Jwt__AccessTokenMinutes=60
Jwt__RefreshTokenDays=30
IDENTITY_SEED_SUPER_EMAIL=super@lucy.local
IDENTITY_SEED_SUPER_PASSWORD=replace-with-initial-super-password
IDENTITY_SEED_SUPER_DISPLAY_NAME=Lucy Super Admin
IDENTITY_SEED_SUPER_AVATAR_PERSONA=super-gold
IDENTITY_SEED_SUPER_ANONYMOUS_DISPLAY_NAME=Lucy Super
IdentitySeed__Super__Email=super@lucy.local
IdentitySeed__Super__Password=replace-with-initial-super-password
IdentitySeed__Super__DisplayName=Lucy Super Admin
IdentitySeed__Super__AvatarPersona=super-gold
IdentitySeed__Super__AnonymousDisplayName=Lucy Super
IDENTITY_HTTP_PORT=5095
